@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

:: Запрашиваем имена компьютеров
set /p pcs=Введите имена компьютеров (через пробел или запятую): 

:: Запрашиваем текст для поиска
set /p search=Введите текст для поиска: 

echo Поиск "!search!" в *.txt на указанных ПК 
echo ---------------------------------------------------- 

:: Заменим запятые на пробелы
set pcs=%pcs:,= %

for %%C in (%pcs%) do (
    echo [%%C]

    :: Выполняем поиск на удалённой машине и выводим список файлов с совпадением
    psexec \\%%C -s cmd /c "findstr /S /I /M /C:\"!search!\" \"C:\Users\*.txt\"" || echo Нет совпадений на %%C
    echo.
)

echo Поиск завершён.
pause
